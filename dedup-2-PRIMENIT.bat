@echo off
chcp 65001 >nul
cd /d "%~dp0"
echo ================================================================
echo   SULTAN — ПРИМЕНИТЬ дедуп каталога (с бэкапом, COMMIT)
echo ================================================================
echo   Заказы, касса, долги, смены — НЕ трогаются.
echo   Минусовые остатки — сохраняются (это не баг).
echo   Сначала будет сделан бэкап в папку backups\
echo ================================================================
echo.
set /p OK="Применить дедуп каталога? Напишите ДА и Enter: "
if /I not "%OK%"=="ДА" if /I not "%OK%"=="DA" (
  echo Отменено.
  pause
  exit /b
)
set APPLY=1
node dedup_catalog.js
echo.
echo ----------------------------------------------------------------
echo Готово. Откройте приложение и обновите рецепт — дубли исчезнут.
echo ----------------------------------------------------------------
pause
